# =============================================================================
# Aurora backend — salin ke .env dan sesuaikan. Jangan commit .env.
# Default di bawah = sama dengan fallback di config (kecuali secret: ganti sendiri).
# =============================================================================

# --- Server (Express) ---
# PORT biasanya diisi otomatis oleh Railway/Render; lokal bisa di-set atau pakai default 8787 di kode.
# PORT=8787
HOST=0.0.0.0
JSON_BODY_LIMIT=2mb

# --- Lynk webhook ---
LYNK_MERCHANT_KEY=s043aRkQXNc-1JizHILH1iIOHdITTsMj
LYNK_SIGNATURE_HEADER=x-lynk-signature

# --- NocoDB ---
NOCODB_BASE_URL=https://app.nocodb.com
NOCODB_API_TOKEN=nc_pat_K1gGmG2-O_wKpp5rftD13nyrRV2voAgchkt1Nesz
NOCODB_TABLE_ID=m03akpbxoa2pi0l
NOCODB_TRANSACTIONS_TABLE_ID=mwlh1kqxg6tqzeh
NOCODB_VOUCHER_DEFAULT_STATUS=active

# Kolom tabel voucher (nama field API NocoDB)
NOCODB_COL_VALUE=value
NOCODB_COL_STATUS=status
NOCODB_COL_EXPIRED_AT=expired_at

# Kolom tabel transaksi
NOCODB_TX_EVENT_NAME=event_name
NOCODB_TX_EMAIL=email
NOCODB_TX_NAMA=nama
NOCODB_TX_REF_ID=refId
NOCODB_TX_TOTAL=total
NOCODB_TX_SIGNATURE=signature
NOCODB_TX_ITEMS=items
NOCODB_TX_STATUS_ACTION=status_action
NOCODB_TX_CODE_ID=code_id
# Isi nama kolom (mis. webhook_json) jika ada; kosongkan jika tidak dipakai
NOCODB_TX_RAW_WEBHOOK=

# --- Email: Resend ATAU Gmail SMTP ---
# Resend — jika diisi, dipakai dulu (butuh RESEND + EMAIL_FROM valid domain / onboarding)
RESEND_API_KEY=

# Gmail SMTP (jika tidak pakai Resend / RESEND_API_KEY kosong)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_SECURE=true hanya jika pakai port SSL langsung (mis. 465)
SMTP_SECURE=false
GMAIL_USER=aurora.aigenerate@gmail.com
# App Password Gmail (bukan sandi login biasa)
GMAIL_APP_PASSWORD=jeqz uska macx jwtx
EMAIL_FROM=aurora.aigenerate@gmail.com
EMAIL_SUBJECT=Kode voucher Anda
VOUCHER_VALID_DAYS=30
